<div class="d-flex justify-content-center gap-2" dir="ltr"
     role="group" aria-label="{{ __('Authentication code') }}" data-mfa-code-input>
   {% for i in 1..this.digits %}
      <input type="text" name="totp_code[]"
             class="form-control text-center fw-bold totp-code-digit"
             maxlength="1" inputmode="numeric" pattern="[0-9]" required
             autocomplete="{{ i == 1 ? 'one-time-code' : 'off' }}"
             aria-label="{{ __('Digit %1$s of %2$s')|format(i, this.digits) }}">
   {% endfor %}
</div>
<script type="module">
    import('/js/modules/Security/MfaCodeInput.js').then((m) => m.MfaCodeInput.init());
</script>
